    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst total = items.length;\nconst errors = items.filter(i => i.json.statusCode && i.json.statusCode >= 400).length;\nreturn [{ json: { status: 'cleanup complete', totalDeleted: total - errors, errors, timestamp: new Date().toISOString() } }];",
        "mode": "runOnceForAllItems"
      },
      "id": "summary",
