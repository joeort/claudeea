      "position": [400, 400],
      "credentials": {
        "googleCalendarOAuth2Api": { "id": "dZ2lCgJhToJOSI7t", "name": "RevOps Calendar - joe@revopsinflection.com" }
      }
    },
    {
      "parameters": {
        "jsCode": "// Collect RevOps events into single item, then pass through\nconst data = $input.first().json;\nconst events = data.items || [];\nreturn [{ json: { calendarLabel: 'revops', events } }];",
        "mode": "runOnceForAllItems"
      },
      "id": "agg-revops",
      "name": "Agg RevOps",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [620, 400]
    },
    {
      "parameters": {
